# Database Configuration
AENEAS_DB_NAME=aeneas
AENEAS_DB_USER=aeneas
AENEAS_DB_PASSWORD=aeneas
POSTGRES_PORT=5432

# Application Configuration
AENEAS_PORT=8080
AENEAS_NO_TLS=true
AENEAS_LOG_LEVEL=info
AENEAS_EXPORTER_TYPE=stdout
AENEAS_HEALTHCHECK_CHECK_INTERVAL=30s

# Note: These environment variables are used by docker-compose.yml
# Copy this file to .env and customize as needed:
#   cp .env.example .env
